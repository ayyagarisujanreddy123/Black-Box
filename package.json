{
  "name": "blackbox",
  "version": "0.1.0",
  "private": true,
  "description": "Local flight recorder for AI coding agents",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayyagarisujanreddy123/Black-Box.git"
  },
  "homepage": "https://github.com/ayyagarisujanreddy123/Black-Box#readme",
  "bugs": {
    "url": "https://github.com/ayyagarisujanreddy123/Black-Box/issues"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.15.0"
  },
  "packageManager": "npm@10.9.3",
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "fsevents@2.3.3": true
  },
  "scripts": {
    "blackbox": "node apps/cli/dist/bin.js",
    "benchmark": "npm run build && node scripts/benchmark.mjs",
    "build": "tsc -b --pretty false && npm run build:assets --workspace @blackbox/viewer && node scripts/package-license.mjs",
    "check": "npm run format && npm run lint && npm run typecheck && npm test && npm run test:e2e",
    "clean": "tsc -b --clean",
    "demo:cleanup": "node demo/scripts/reset.mjs --clean",
    "demo:offline": "npm run build && node demo/scripts/run-offline.mjs",
    "demo:reset": "node demo/scripts/reset.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "package:smoke": "npm run build && node scripts/package-smoke.mjs",
    "release:preflight": "node scripts/release-preflight.mjs",
    "test": "npm run test:unit",
    "test:e2e": "npm run build && vitest run --config vitest.e2e.config.ts",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.check.json --pretty false"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.20.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "fsevents": false
  }
}
